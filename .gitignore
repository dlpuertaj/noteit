# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
.metadata
/build/
/coverage/

# Platform folders — only Android is used; others excluded
/ios/
/linux/
/web/
/macos/
/windows/

# Signing secrets — never commit these
android/key.properties
android/app/*.jks
android/app/*.keystore

# Android build artifacts
/android/app/debug
/android/app/profile
/android/app/release
/android/.gradle/
/android/captures/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json
